# Frontend (Vite)
VITE_SUPABASE_URL=""
VITE_SUPABASE_ANON_KEY=""
# For local Supabase dev, copy values from `supabase status` after `npm run supabase:start`.
# Optional in local dev (leave empty to use Vite /api proxy).
# Required in production frontend when backend is hosted on a separate domain.
VITE_API_BASE_URL=""
VITE_TURNSTILE_SITE_KEY=""

# Backend (Express)
PORT=8787
API_BODY_LIMIT="80mb"
APP_ORIGIN="http://localhost:3000"
SUPABASE_URL="https://YOUR_PROJECT_ID.supabase.co"
SUPABASE_ANON_KEY="YOUR_SUPABASE_ANON_KEY"
SUPABASE_SERVICE_ROLE_KEY="YOUR_SUPABASE_SERVICE_ROLE_KEY"
SUPABASE_STORAGE_BUCKET="generated-images"
# Local dev usually uses `http://127.0.0.1:54321` plus anon/service_role keys from `supabase status`.
LINGKE_API_BASE_URL=""
LINGKE_API_KEY=""
LINGKE_BEARER_TOKEN=""
TURNSTILE_SECRET_KEY=""
GENERATION_COST=50

GENERATION_MAX_CONCURRENCY=6
